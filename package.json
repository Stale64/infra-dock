{
  "name": "infra-dock",
  "version": "1.0.0",
  "description": "A macOS desktop app to configure, start, stop and manage local servers (Redis, MySQL, PostgreSQL, MongoDB and more) from one place.",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "dev.infradock.app",
    "productName": "Infra Dock",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "Infra Dock",
      "icon": "assets/icon.icns"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
